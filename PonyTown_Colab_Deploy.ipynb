 \"- 📱 **跨平台访问** - 支持任何设备的浏览器访问\\n\",\n    \"\\n\",\n    \"🎉 **现在就开始游戏，享受这个复活的经典多人在线游戏吧！**\"\n   ]\n  }\n ],\n \"metadata\": {\n  \"colab\": {\n   \"provenance\": [],\n   \"collapsed_sections\": [\n    \"step1\",\n    \"step2\",\n    \"step3\",\n    \"step4\",\n    \"logs\"\n   ]\n  },\n  \"kernelspec\": {\n   \"display_name\": \"Python 3\",\n   \"language\": \"python\",\n   \"name\": \"python3\"\n  },\n  \"language_info\": {\n   \"name\": \"python\",\n   \"version\": \"3.8.10\"\n  }\n },\n \"nbformat\": 4,\n \"nbformat_minor\": 0\n}